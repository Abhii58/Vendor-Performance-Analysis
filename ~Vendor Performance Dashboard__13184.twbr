              <calculation class='tableau' formula='(&#13;&#10;SUM([TotalPurchaseQuantity])&#13;&#10;-&#13;&#10;SUM([TotalSalesQuantity])&#13;&#10;)&#13;&#10;*&#13;&#10;AVG([PurchasePrice])' />
