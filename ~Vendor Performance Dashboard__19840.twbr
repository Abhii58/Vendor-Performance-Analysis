      <column datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([TotalPurchaseDollars]) / TOTAL(SUM([TotalPurchaseDollars]))'>
          <table-calc ordering-field='[federated.1rnkokn1q5lmur18tj8ao1qrqeu0].[none:VendorName:nk]' ordering-type='Field' />
        </calculation>
      </column>
      <column datatype='real' default-format='p0.00%' name='[Calculation2]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([TotalPurchaseDollars]) / TOTAL(SUM([TotalPurchaseDollars]))'>
          <table-calc ordering-type='Columns' />
        </calculation>
      </column>
      <column datatype='real' default-format='p0.00%' name='[Calculation3]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([TotalPurchaseDollars]) / TOTAL(SUM([TotalPurchaseDollars]))'>
          <table-calc ordering-type='Columns' />
        </calculation>
      </column>
      <column caption='Unsold capital ' datatype='real' name='[Calculation_1181492950155264]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;SUM([TotalPurchaseQuantity])&#13;&#10;-&#13;&#10;SUM([TotalSalesQuantity])&#13;&#10;)&#13;&#10;*&#13;&#10;AVG([PurchasePrice])' />
      </column>
      <column caption='Low sales brands ' datatype='boolean' name='[Calculation_1363396969357313]' role='measure' type='nominal'>
        <calculation class='tableau' formula='SUM([TotalSalesDollars]) &lt; WINDOW_AVG(SUM([TotalSalesDollars]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
